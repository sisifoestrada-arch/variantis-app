generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Module B: Product-level variant display configuration
model ProductConfig {
  id                String   @id @default(cuid())
  shop              String
  productId         String
  productTitle      String   @default("")
  productHandle     String   @default("")
  enabled           Boolean  @default(true)
  splitByOption     String   @default("Color")
  hideOutOfStock    Boolean  @default(false)
  showOnlyDiscount  Boolean  @default(false)
  hideWithoutImage  Boolean  @default(false)
  titleFormat       String   @default("product_variant") // product_only | variant_only | product_variant | custom
  customTitleFormat String   @default("{product} - {variant}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  variants          ProductVariantConfig[]

  @@unique([shop, productId])
}

// Per-variant display config within a product
model ProductVariantConfig {
  id            String   @id @default(cuid())
  shop          String
  productId     String
  variantId     String
  variantTitle  String
  imageUrl      String   @default("")
  hoverImageUrl String   @default("")
  visible       Boolean  @default(true)
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       ProductConfig @relation(fields: [shop, productId], references: [shop, productId])

  @@unique([shop, productId, variantId])
}
