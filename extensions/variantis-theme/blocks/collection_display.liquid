{% comment %}
  Variantis – Module B: Collection Display
  App Embed Block — injects on collection, index, and search templates.
{% endcomment %}

<script id="variantis-collection-data" type="application/json">
  {% if template.name == "collection" and collection %}
    [{{ collection.metafields.variantis.display_config.value | default: "null" }}]
  {% elsif template.name == "index" %}
    {{ shop.metafields.variantis.homepage_configs.value | default: "[]" }}
  {% elsif template.name == "search" %}
    {{ shop.metafields.variantis.search_configs.value | default: "[]" }}
  {% else %}
    []
  {% endif %}
</script>

<script src="{{ 'variantis-collection.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Variantis Collections",
  "target": "body",
  "templates": ["collection", "index", "search"],
  "settings": []
}
{% endschema %}
